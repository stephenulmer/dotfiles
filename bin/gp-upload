#!/bin/bash
##
## Upload Videos to YouTube
##

YTUL=$(command -v youtubeuploader)
if [ -z "${YTUL}" ] ; then
  echo "This script requires youtubeuploader."
  exit 1
fi

if [ -f .yt-playlist ] ; then
  playlistARG="-playlistID $(cat .yt-playlist)"
else
  echo "No .yt-playlist file found. Not adding to a playlist."
fi

all_MP4s=(*.MP4)
ARGV=( "${@:-${all_MP4s[@]}}" )
for s in "${ARGV[@]}" ; do
  #json=${s%.MP4}.JSON
  json="$(basename ${s} .MP4).JSON"
  if [ -f "${json}" ]; then
    echo "${json} exits; Skipping ${s}"
  else
    title=$(basename ${s} | sed -e 's/.MP4$//g' -e 's/_[FU]HD//g' -e 's/_/ /g' ) 
    ${YTUL} -filename "${s}" \
      -title "${title}" \
      -description "${title}" \
      ${playlistARG:- } \
      -metaJSONout "${json}" \
      -notify false
  fi
done
